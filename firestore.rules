rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only authenticated user can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Domains: authenticated users can read, managers can write
    match /domains/{domain} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role == 'manager';
    }

    // Tests: authenticated users can read/write their own sessions
    match /tests/{testId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Sessions: same as tests
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Audit log: append-only for authenticated users
    match /audit_log/{entryId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.role == 'manager';
      allow write: if false;
    }

    // Anomalies: authenticated users can read, managers can write
    match /anomalies/{anomalyId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role == 'manager';
    }

    // Break schedules: authenticated users can read/write
    match /break_schedules/{scheduleId} {
      allow read, write: if request.auth != null;
    }

    // QR specimens: authenticated users can read/write
    match /qr_specimens/{specimenId} {
      allow read, write: if request.auth != null;
    }
  }
}
